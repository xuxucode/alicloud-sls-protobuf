{
  "name": "alicloud-sls-protobuf",
  "version": "1.2.0",
  "description": "Aliyun SLS Node.js SDK by protobuf",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "author": "Edward",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xuxucode/alicloud-sls-protobuf.git"
  },
  "bugs": {
    "url": "https://github.com/xuxucode/alicloud-sls-protobuf/issues"
  },
  "homepage": "https://github.com/xuxucode/alicloud-sls-protobuf#readme",
  "scripts": {
    "build": "bun run clean && bun run build:proto && bun run build:ts",
    "build:proto": "bun run format && bun run generate",
    "build:ts": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "buf lint",
    "format": "buf format -w",
    "generate": "buf generate",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/bun": "^1.3.9",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "typescript": "^5.9.3"
  }
}
